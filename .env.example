APP_NAME=FichAqui
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8001

# Porta HTTP do container (artisan serve). No Coolify, defina a mesma em "Port Exposes".
APP_PORT=8001

FRONTEND_URL=http://localhost:3000

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
# Docker (api + postgres no compose): DB_HOST=postgres, DB_PORT=5432
# Local fora do Docker / cliente SQL no host: DB_HOST=127.0.0.1, DB_PORT=5433
DB_HOST=127.0.0.1
DB_PORT=5433
DB_DATABASE=fich_aqui
DB_USERNAME=fich_aqui
DB_PASSWORD=secret

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# URL absoluta de imagens na API (opcional; se vazio, usa APP_URL)
# ASSET_URL=http://localhost:8001

# =============================================================================
# Mercado Pago ? SOMENTE neste arquivo (FichAqui-BackEnd/.env)
# NUNCA copie para FichAqui-FrontEnd/.env.local
# Painel: https://www.mercadopago.com.br/developers/panel/app
# =============================================================================
#
# MP_PUBLIC_KEY  ? Credenciais de teste/produção ? Public Key
#                  O front lê via GET /api/payments/config (MercadoPago.js)
#
# MP_ACCESS_TOKEN ? Credenciais ? Access Token (grafia: ACCESS com dois C)
#                  Apenas no servidor (Payments API). Nunca no browser.
#
MP_PUBLIC_KEY=
MP_ACCESS_TOKEN=
MP_WEBHOOK_SECRET=
# URL publica registrada no painel MP (uma por ambiente). Rotas aceitas pelo app:
#   POST {APP_URL}/webhook-mp          (recomendada)
#   POST {APP_URL}/api/webhooks/mercadopago  (alias legado)
# Producao/staging: URL fixa HTTPS (ex. abaixo). Dev local: tunel ? ver
# docs/integrations/mercadopago-qr-orders.md#webhooks
MP_WEBHOOK_URL=https://fichaqui.baiacubo.tech/webhook-mp
MP_SANDBOX=true
# Com MP_SANDBOX=true, checkout via cartao ou PIX exige e-mail de comprador de
# teste terminado em @testuser.com (validacao em PedidoCheckoutService).
# Crie contas em: painel MP > Suas integracoes > Credenciais de teste >
# Contas de teste (tipo Comprador). O seed padrao usa maria@testuser.com ?
# faca login com essa conta ou atualize o e-mail do usuario antes de pagar.
# Producao (MP_SANDBOX=false): qualquer e-mail valido do usuario autenticado.
# Ver docs/integrations/mercadopago-qr-orders.md#sandbox-compradores-de-teste
MP_LOCALE=pt-BR

# PIX in-app (padrao): online ? POST /v1/orders type:online (Checkout API Orders)
# Legado: payments ? POST /v1/payments
# Caixa fisico: orders + MP_QR_EXTERNAL_POS_ID ? POST /v1/orders type:qr
MP_PIX_DRIVER=online
MP_QR_MODE=dynamic
MP_QR_EXPIRATION=PT15M
# Obrigatorio somente com MP_PIX_DRIVER=orders
# MP_QR_EXTERNAL_POS_ID=

MP_PIX_EXPIRATION=PT15M
